{
  "expo": {
    "name": "AvenSU-Orienta",
    "slug": "avensu-orienta",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "avensu",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0EA5E9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "tg.avensu.orienta",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera used for profile avatar and document upload.",
        "NSPhotoLibraryUsageDescription": "Photo library used for profile and document upload.",
        "NSLocationWhenInUseUsageDescription": "Location used to suggest nearby schools."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0EA5E9"
      },
      "package": "tg.avensu.orienta"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-camera",
      "expo-image-picker"
    ],
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      },
      "apiBaseUrl": "http://localhost:8000/api/v1"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/your-project-id"
    }
  }
}
