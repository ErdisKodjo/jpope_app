# ──────────── Django ────────────
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,avensu-orienta.tg
DJANGO_DEBUG=True

# ──────────── Base de données ────────────
POSTGRES_DB=avensu
POSTGRES_USER=avensu
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_SSLMODE=prefer

# ──────────── Redis ────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# ──────────── Email ────────────
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@avensu-orienta.tg

# ──────────── CORS ────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ──────────── IA / Chatbot ────────────
CHATBOT_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# ──────────── Stockage S3 (prod) ────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=avensu-media
AWS_REGION=eu-west-3
AWS_S3_ENDPOINT_URL=

# ──────────── Paiements ────────────
FLOOZ_API_KEY=
TMONEY_API_KEY=
# Secret partagé pour vérifier la signature HMAC-SHA256 des callbacks provider.
# Obligatoire pour accepter les callbacks Mobile Money (Flooz/TMoney).
PAYMENT_WEBHOOK_SECRET=change-me-to-a-long-random-string

# ──────────── Monitoring ────────────
SENTRY_DSN=
