# Configuration de l'app mobile AvenSU-Orienta
# Copiez ce fichier en .env et adaptez selon votre environnement

# URL de l'API Django (en dev : IP LAN du serveur)
API_BASE_URL=http://localhost:8000/api/v1

# Pour test sur device physique, utilisez l'IP LAN du serveur :
# API_BASE_URL=http://192.168.1.50:8000/api/v1

# Clés OAuth (à configurer côté Django aussi)
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
APPLE_OAUTH_CLIENT_ID=your-apple-client-id

# Stripe (pour les paiements carte)
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
